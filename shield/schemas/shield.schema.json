{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shield Project Config",
  "description": "Project configuration file (.shield.json) committed to the repo",
  "type": "object",
  "required": ["project", "domains"],
  "properties": {
    "project": { "type": "string", "description": "Project name — used as key in ~/.shield/projects/" },
    "domains": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "Active domains for this project" },
    "output_dir": { "type": "string", "default": "docs/shield", "description": "Root directory under which Shield writes research, prd, and plan artifacts" },
    "reviewers": {
      "type": "object",
      "properties": {
        "auto_select": { "type": "boolean", "default": true, "description": "Automatically select reviewers based on content" },
        "always_include": { "type": "array", "items": { "type": "string" }, "default": [], "description": "Reviewers that always run regardless of auto-detection" },
        "never_include": { "type": "array", "items": { "type": "string" }, "default": [], "description": "Reviewers that are skipped even if auto-detected" }
      },
      "additionalProperties": false
    },
    "devcontainer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "stacks_detected": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required": {
          "enum": ["ask", "true", "false"]
        },
        "firewall_extra_allowlist": {
          "type": "array",
          "items": { "type": "string", "format": "hostname" },
          "uniqueItems": true
        }
      }
    },
    "external_skills": {
      "type": "object",
      "description": "External plugin skills mapped to phases",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "research": { "type": "array", "items": { "type": "string" } },
          "plan": { "type": "array", "items": { "type": "string" } },
          "implement": { "type": "array", "items": { "type": "string" } },
          "review": { "type": "array", "items": { "type": "string" } },
          "debug": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "backlog": {
      "type": "object",
      "description": "Shield backlog settings (docs/shield/backlog.json)",
      "properties": {
        "auto_reconcile": { "type": "boolean", "default": true, "description": "When false, disables eager prune and lazy sweep, leaving manual remove only (kill switch)" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
