{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shield Credentials",
  "description": "PM tool API tokens (~/.shield/credentials.json) — never commit this file",
  "type": "object",
  "properties": {
    "clickup": {
      "type": "object",
      "properties": { "api_token": { "type": ["string", "null"] } },
      "additionalProperties": false
    },
    "jira": {
      "type": "object",
      "properties": {
        "api_token": { "type": ["string", "null"] },
        "base_url": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": { "type": "object", "description": "Future PM tool credentials" }
}
