{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shield.tesseract/schema/plan-sidecar/1.5",
  "title": "Shield plan.json sidecar — schema 1.5",
  "description": "Machine-readable counterpart of shield/skills/general/plan-docs/sidecar-schema.md. Source of truth for shield/scripts/validate_plan.py.",
  "type": "object",
  "required": ["version", "project", "name", "epics"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "description": "Sidecar schema version. Current is 1.5.",
      "type": "string",
      "enum": ["1.0", "1.1", "1.2", "1.3", "1.4", "1.5"]
    },
    "project": { "type": "string", "minLength": 1 },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "phase": { "type": ["string", "null"] },
    "source_research": { "type": ["string", "null"] },
    "source_prd": { "type": ["string", "null"] },
    "prd_rubric_version_at_planning": { "type": ["string", "null"] },
    "last_aligned_with": {
      "description": "Schema 1.3+ — git commit SHA of the most recent /implement run that closed a story. Null until first close.",
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      ]
    },
    "lld_components": {
      "type": "array",
      "description": "Registry of LLD components referenced by stories' design_refs[]. Single fact per component; type is stated once here.",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Kebab-case component identifier; matches docs/lld/<name>.md filename."
          },
          "type": {
            "type": "string",
            "enum": ["backend", "infra"],
            "description": "Selects the LLD template variant."
          },
          "fork_blob_sha": {
            "type": ["string", "null"],
            "pattern": "^[a-f0-9]{40}$|^$",
            "description": "git hash-object of docs/lld/<name>.md at /plan-draft time; null when canonical didn't exist."
          }
        }
      }
    },
    "milestones": {
      "type": "array",
      "items": { "$ref": "#/$defs/milestone" }
    },
    "epics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/epic" }
    },
    "metadata": { "type": "object" }
  },
  "$defs": {
    "milestone": {
      "type": "object",
      "required": ["id", "name", "outcome", "exit_criteria"],
      "additionalProperties": true,
      "properties": {
        "id":      { "type": "string", "pattern": "^M[0-9]+$" },
        "name":    { "type": "string", "minLength": 1 },
        "outcome": { "type": "string", "minLength": 1 },
        "exit_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string", "pattern": "^M[0-9]+$" }
        },
        "touches_lld": {
          "type": "array",
          "description": "Persisted rollup of lld_components[].name referenced by this milestone's stories' design_refs[]. /plan-review enforces the drift gate.",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        }
      }
    },
    "epic": {
      "type": "object",
      "required": ["id", "name", "stories"],
      "additionalProperties": true,
      "properties": {
        "id":      { "type": "string", "pattern": "^EPIC-[0-9]+$" },
        "name":    { "type": "string", "minLength": 1 },
        "stories": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/story" }
        },
        "pm_id":  { "type": ["string", "null"] },
        "pm_url": { "type": ["string", "null"] }
      }
    },
    "story": {
      "type": "object",
      "required": ["id", "name", "status", "description", "tasks", "acceptance_criteria"],
      "additionalProperties": true,
      "properties": {
        "id":          { "type": "string", "pattern": "^EPIC-[0-9]+-S[0-9]+$" },
        "name":        { "type": "string", "minLength": 1 },
        "status":      { "type": "string", "enum": ["ready", "in-progress", "in-review", "done", "blocked"] },
        "assignee":    { "type": ["string", "null"] },
        "priority":    { "type": ["string", "null"], "enum": ["low", "medium", "high", null] },
        "week":        { "type": ["string", "integer", "null"] },
        "milestone_id": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^M[0-9]+$" }
          ]
        },
        "description": { "type": "string", "minLength": 1 },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "design_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/design_ref" }
        },
        "pm_id":  { "type": ["string", "null"] },
        "pm_url": { "type": ["string", "null"] }
      }
    },
    "design_ref": {
      "type": "object",
      "required": ["doc", "label"],
      "additionalProperties": true,
      "properties": {
        "doc":        { "type": "string", "enum": ["trd", "lld", "prd"] },
        "component":  { "type": ["string", "null"] },
        "section_id": { "type": ["string", "null"] },
        "anchor_url": { "type": ["string", "null"] },
        "label":      { "type": "string", "minLength": 1 },
        "stale":      { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "doc": { "const": "lld" } },
            "required": ["doc"]
          },
          "then": {
            "properties": {
              "component": { "type": "string", "pattern": "^[a-z0-9-]+$" }
            },
            "required": ["component"]
          }
        }
      ]
    }
  }
}
